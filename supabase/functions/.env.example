# Alsaiti Voice — Edge Function secrets. Set with `supabase secrets set --env-file ./supabase/functions/.env`.
# NONE of these may ever ship to the browser / Expo / git. Fill from provider consoles.
# (SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY are injected automatically by the
#  Supabase runtime — you do NOT set them here; listed for reference only.)

# --- Public URLs the functions need to build redirect + return links ---
PUBLIC_FUNCTIONS_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1
PUBLIC_APP_URL=https://mohammedkarim-mk.github.io/alsaiti_voice_claude_fresh_start_pack--3-/

# --- 32-byte key for envelope-encrypting OAuth tokens (hex = 64 chars, or base64) ---
# Generate: openssl rand -hex 32
OAUTH_CREDENTIAL_ENCRYPTION_KEY=

# --- HubSpot (the reference provider — the one wired end-to-end) ---
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# --- Other CRM providers (authorise flow works once filled; live test/metadata still HubSpot-only) ---
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
HIGHLEVEL_CLIENT_ID=
HIGHLEVEL_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# SALESFORCE_LOGIN_URL=https://test.salesforce.com   # sandbox override
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.eu          # EU/IN/AU data-centre override
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_MODE=common
# DYNAMICS_RESOURCE=https://YOURORG.crm.dynamics.com

# --- Telnyx (primary phone provider) ---
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=          # portal Ed25519 public key (base64) — required for webhook verification
