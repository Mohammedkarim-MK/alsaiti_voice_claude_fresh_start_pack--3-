      "backgroundColor": "#020B1F"
    },
    "ios": { "supportsTablet": true },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020B1F"
      },
      "edgeToEdgeEnabled": true
    },
    "web": { "favicon": "./assets/favicon.png" }
  }
}
