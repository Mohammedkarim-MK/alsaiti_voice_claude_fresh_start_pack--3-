{
  "expo": {
    "name": "Alsaiti Growth",
    "slug": "alsaiti-go",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#020B1F",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
